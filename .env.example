# ── LLM keys ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=                   # optional — for reranking

# ── Default chat model (overridable per-request) ────────────────────────────────
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-6

# ── Infrastructure (overridden by docker-compose env) ──────────────────────────
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_USE_SSL=false

# ── App ─────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
DEFAULT_ORG_ID=default-org
EMBEDDING_PROFILE=openai-small
QDRANT_COLLECTION=docs_openai_small_1536
